generator client {
  provider        = "prisma-client"
  output   = "../server/utils/generated/prisma"
  engineType             = "client"
  runtime                = "nodejs"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
  previewFeatures = []
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String        @id @default(cuid())
  name          String        @default("Anonymous")
  status        Boolean       @default(false) // 0: active, 1: frozen, 2: deleted
  phone         String?
  email         String        @default("mplfboard@gmail.com")
  emailVerified Boolean       @default(false)
  permission    Int           @default(0) // main admin, admin, editor, 0: viewer
  image         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @default(now()) @updatedAt
  Sessions      Session[]
  Accounts      Account[]
  Donations     Donation[]
  Donors        Donor[]
  Grants        Grant[]
  Grantors      Grantor[]
  Events        Event[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  @@map("verification")
}

model AccountCreationRequest {
  id    String @id @default(cuid())
  name  String @default("Anonymous")
  email String
}

model Donor {
  id                     String     @id @default(cuid())
  boardMemberId          String
  boardMember            User      @relation(fields: [boardMemberId], references: [id], onDelete: Restrict)
  name                   String     @unique @default("Anonymous")
  address                String?
  phone                  String?
  email                  String?
  preferredCommunication String? // phone or email
  notes                  String?
  webLink                String?
  isAuthor               Boolean    @default(false)
  organization           String?
  Donations              Donation[]
  Events                 Event[]    @relation("DonorToEvent")
}

model Grantor {
  id                     String  @id @default(cuid())
  boardMemberId          String
  boardMember            User   @relation(fields: [boardMemberId], references: [id], onDelete: Restrict)
  name                   String  @default("Anonymous")
  phone                  String?
  address                String?
  email                  String?
  preferredCommunication String? // phone or email
  notes                  String?
  webLink                String?
  organization           String?
  Grants                 Grant[]
}

model Donation {
  id                String    @id @default(cuid())
  boardMemberId     String
  boardMember       User     @relation(fields: [boardMemberId], references: [id], onDelete: Restrict)
  donorId           String?
  donor             Donor?    @relation(fields: [donorId], references: [id], onDelete: Restrict)
  isAuthor          Boolean   @default(false)
  eventId           String?
  event             Event?    @relation(fields: [eventId], references: [id], onDelete: Restrict)
  method            String?
  monetaryAmount    String?
  nonMonetaryAmount String?
  status            Int       @default(0) // 0: pending, 1: completed
  notes             String?
  reason            String?
  receivedDate      DateTime?
  lastEditDate      DateTime?
}

model Grant {
  id                String    @id @default(cuid())
  boardMemberId     String
  boardMember       User     @relation(fields: [boardMemberId], references: [id], onDelete: Restrict)
  grantorId         String?
  grantor           Grantor?  @relation(fields: [grantorId], references: [id], onDelete: Restrict)
  purpose           String?
  method            String?
  monetaryAmount    String?
  nonMonetaryAmount String?
  status            Int?      @default(0) // 0: requested, 1: completed
  reimburse         Boolean   @default(false)
  notes             String?
  proposedDate      DateTime?
  receivedDate      DateTime?
  lastEditDate      DateTime?
}

model Event {
  id                String    @id @default(cuid())
  boardMemberId     String
  boardMember       User     @relation(fields: [boardMemberId], references: [id], onDelete: Restrict)
  eventName         String
  eventDate         DateTime?
  //like notes
  description       String?
  Donors            Donor[]   @relation("DonorToEvent")
  Donations         Donation[]
}